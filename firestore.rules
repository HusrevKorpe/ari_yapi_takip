rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profile: only the user themselves can read/write
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Organization document
    match /organizations/{orgId} {
      // Admin 1: kendi uid'ini orgId olarak kullanarak ilk kez org oluşturur.
      // Bu noktada users/{uid} henüz yazılmamış olabilir, isOrgMember çalışmaz.
      allow create: if request.auth != null && request.auth.uid == orgId;

      // Sonraki okuma/güncelleme/silme: sadece org üyeleri
      allow read, update, delete: if request.auth != null && isOrgMember(orgId);

      // Alt koleksiyonlar (workers, sites, attendance, ...)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && isOrgMember(orgId);
      }
    }

    // Kullanıcının kendi organizasyonuna üye olup olmadığını kontrol et
    function isOrgMember(orgId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.exists && userDoc.data.organizationId == orgId;
    }

    // Diğer her şeyi reddet
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
